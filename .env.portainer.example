# OGI — Portainer self-hosted deployment example
# Copy to .env and fill in your values, then add as stack environment variables in Portainer.

# --- Database ---
# NOTE: Password appears in both vars below — update both if rotating
# If your password contains special characters (e.g. @), URL-encode them in OGI_DATABASE_URL
# (e.g. @ becomes %40)
OGI_DB_PASSWORD=changeme
OGI_DATABASE_URL=postgresql://ogi:changeme@ogi-db:5432/ogi

# --- Redis ---
OGI_REDIS_URL=redis://ogi-redis:6379/0

# --- App ---
OGI_USE_SQLITE=false
OGI_AUTO_RUN_MIGRATIONS=true
OGI_RUN_DB_MIGRATIONS=false
OGI_HOST=0.0.0.0
OGI_PORT=8000
OGI_CORS_ORIGINS=http://your-domain.example.com,http://your-server-ip:3030
OGI_DEPLOYMENT_MODE=self-hosted
OGI_TELEMETRY_ENABLED=false

# --- Security ---
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
OGI_API_KEY_ENCRYPTION_KEY=your-fernet-key-here

# --- Admin ---
OGI_ADMIN_EMAILS=your@email.com

# --- Frontend (points browser at backend) ---
VITE_API_URL=http://your-domain.example.com
