# OGI Environment Configuration
# Copy this file to .env and keep only the values you actually need.
# List values may be provided either as JSON arrays or comma-separated strings.

# -----------------------------------------------------------------------------
# Core app / server
# -----------------------------------------------------------------------------

OGI_APP_NAME=OGI
OGI_HOST=0.0.0.0
OGI_PORT=8000
OGI_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Local default is SQLite. For PostgreSQL-based setups set OGI_USE_SQLITE=false.
OGI_USE_SQLITE=true
OGI_DB_PATH=ogi.db

# PostgreSQL connection string (used when OGI_USE_SQLITE=false)
# docker-compose.dev uses its own internal db hostname and overrides this value.
OGI_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ogi

# -----------------------------------------------------------------------------
# Redis / async transform jobs
# -----------------------------------------------------------------------------

OGI_REDIS_URL=redis://localhost:6379/0
OGI_RQ_QUEUE_NAME=transforms
OGI_TRANSFORM_TIMEOUT=300

# -----------------------------------------------------------------------------
# Migrations / startup
# -----------------------------------------------------------------------------

# Local non-SQLite app startup can auto-run Alembic migrations.
OGI_AUTO_RUN_MIGRATIONS=true

# Container entrypoint migration controls.
OGI_RUN_DB_MIGRATIONS=false
OGI_DB_MIGRATION_RETRIES=30
OGI_DB_MIGRATION_DELAY_SECONDS=2

# -----------------------------------------------------------------------------
# Supabase / auth (optional)
# -----------------------------------------------------------------------------

# OGI_SUPABASE_URL=https://your-project.supabase.co
# OGI_SUPABASE_ANON_KEY=eyJ...
# OGI_SUPABASE_SERVICE_ROLE_KEY=eyJ...
# OGI_SUPABASE_JWT_SECRET=your-jwt-secret

# Media storage for Person images and similar protected uploads.
# The Supabase bucket should be private if you use Supabase storage.
OGI_MEDIA_DIR=media
OGI_MEDIA_BUCKET_NAME=media
OGI_MEDIA_UPLOAD_MAX_BYTES=5242880

# Frontend redirect URL used in hosted auth flows.
# OGI_SUPABASE_REDIRECT_URL=https://your-domain.example/auth/callback

# -----------------------------------------------------------------------------
# Cloud billing / transform cooldowns (cloud instance only)
# -----------------------------------------------------------------------------

# Billing only has an effect when OGI_DEPLOYMENT_MODE=cloud and this flag is true.
# Self-hosted deployments should leave this disabled.
OGI_CLOUD_BILLING_ENABLED=false

# Free cloud users can run one transform per cooldown window.
OGI_FREE_TRANSFORM_COOLDOWN_SECONDS=1800

# Supporter cooldown. Keep 0 for no paid-user cooldown.
OGI_PAID_TRANSFORM_COOLDOWN_SECONDS=0

# Stripe subscription setup for the Supporter plan.
# OGI_STRIPE_SECRET_KEY=sk_live_...
# OGI_STRIPE_WEBHOOK_SECRET=whsec_...
# OGI_STRIPE_SUPPORTER_PRICE_ID=price_...
OGI_STRIPE_SUPPORTER_AMOUNT_CENTS=300
OGI_STRIPE_SUPPORTER_CURRENCY=usd

# Optional explicit redirect URLs for Checkout and the billing portal.
# If unset, the backend derives URLs from the request origin.
# OGI_BILLING_SUCCESS_URL=https://your-domain.example/projects?billing=success
# OGI_BILLING_CANCEL_URL=https://your-domain.example/projects?billing=cancelled
# OGI_BILLING_PORTAL_RETURN_URL=https://your-domain.example/projects

# -----------------------------------------------------------------------------
# Plugins / Transform Hub / registry
# -----------------------------------------------------------------------------

OGI_PLUGIN_DIRS=plugins,../plugins
OGI_DEPLOYMENT_MODE=self-hosted
OGI_REGISTRY_REPO=opengraphintel/ogi-transforms
OGI_REGISTRY_CACHE_TTL=3600

# Optional global max-setting overrides for transforms and plugins.
# Format: key=value,key2=value2 or JSON object. Use none/null/off/unlimited to remove a cap.
# Examples:
# OGI_TRANSFORM_SETTING_MAX_OVERRIDES=max_results=50,max_urls=25,max_links=40
# OGI_TRANSFORM_SETTING_MAX_OVERRIDES=max_results=none,max_content_chars=none
OGI_TRANSFORM_SETTING_MAX_OVERRIDES=

# Optional GitHub token for higher registry/API limits.
# OGI_GITHUB_TOKEN=github_pat_1...

# Comma-separated admin emails for registry/plugin admin actions.
OGI_ADMIN_EMAILS=admin@example.com
OGI_TELEMETRY_ENABLED=true
OGI_TELEMETRY_LEVEL=full

# -----------------------------------------------------------------------------
# API key storage and transform secret-injection policy
# -----------------------------------------------------------------------------

# 32-byte urlsafe base64 Fernet key used for encrypted API key storage.
OGI_API_KEY_ENCRYPTION_KEY=replace-with-fernet-key

# If false, community-tier plugins cannot receive stored API keys automatically.
OGI_API_KEY_INJECTION_ALLOW_COMMUNITY_PLUGINS=true

# If true, only tiers in OGI_API_KEY_INJECTION_ALLOWED_TIERS may receive stored keys.
OGI_API_KEY_INJECTION_TRUSTED_TIERS_ONLY=false
OGI_API_KEY_INJECTION_ALLOWED_TIERS=official,verified

# Optional service-level controls. Leave empty for no allow/block filtering.
OGI_API_KEY_SERVICE_ALLOWLIST=
OGI_API_KEY_SERVICE_BLOCKLIST=

# -----------------------------------------------------------------------------
# Error reporting / debugging
# -----------------------------------------------------------------------------

OGI_EXPOSE_ERROR_DETAILS=false

# -----------------------------------------------------------------------------
# Cloud sandbox settings
# -----------------------------------------------------------------------------

OGI_SANDBOX_ENABLED=false
OGI_SANDBOX_TIMEOUT=30
OGI_SANDBOX_MEMORY_MB=256
OGI_SANDBOX_ALLOWED_TIERS=official,verified

# -----------------------------------------------------------------------------
# Boot-time plugin dependency install (container entrypoint)
# -----------------------------------------------------------------------------

OGI_BOOT_REQUIREMENTS_ENABLE=true
OGI_BOOT_REQUIREMENTS_FILE=/app/plugins/requirements.txt
OGI_BOOT_LOCK_FILE=/app/plugins/ogi-lock.json
OGI_BOOT_REQUIREMENTS_STRICT=false
OGI_BOOT_REQUIREMENTS_CACHE_DIR=/tmp/ogi-boot

# -----------------------------------------------------------------------------
# Frontend / image selection
# -----------------------------------------------------------------------------

OGI_FRONTEND_PORT=3000
OGI_IMAGE_TAG=latest

# Optional explicit production image overrides.
# OGI_BACKEND_IMAGE=ghcr.io/khashashin/ogi-backend
# OGI_WORKER_IMAGE=ghcr.io/khashashin/ogi-worker
# OGI_FRONTEND_IMAGE=ghcr.io/khashashin/ogi-frontend

# -----------------------------------------------------------------------------
# CLI
# -----------------------------------------------------------------------------

# Optional bearer token for CLI calls against an auth-enabled backend.
# OGI_CLI_BEARER_TOKEN=
